<script type="application/javascript">
// Required hooks for pythons.js — all no-ops.
globalThis.__canvas_resized = function(){};
async function custom_onload(debug_hidden){}
function custom_prerun(){}
function custom_postrun(){}
function debug(){ python.config.debug = true; }
