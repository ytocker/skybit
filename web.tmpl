// Force canvas CSS dimensions with inline !important. MutationObserver
// re-applies on every mutation (beats emscripten Browser.updateCanvasDimensions
// inline !important — verified behavior per emscripten issue #6353).
(function(){
  'use strict';
  function apply(c){
    if (!c) return;
    var vw = window.innerWidth, vh = window.innerHeight;
    if (c.style.width === vw + 'px' && c.style.height === vh + 'px') return;
    c.style.setProperty('position',        'fixed',     'important');
    c.style.setProperty('left',            '0',         'important');
    c.style.setProperty('top',             '0',         'important');
    c.style.setProperty('right',           'auto',      'important');
    c.style.setProperty('bottom',          'auto',      'important');
    c.style.setProperty('width',           vw + 'px',   'important');
    c.style.setProperty('height',          vh + 'px',   'important');
    c.style.setProperty('margin',          '0',         'important');
    c.style.setProperty('transform',       'none',      'important');
    c.style.setProperty('image-rendering', 'pixelated', 'important');
    c.style.setProperty('z-index',         '1',         'important');
    c.style.setProperty('display',         'block',     'important');
  }
  var obs = new MutationObserver(function(){
    var c = document.getElementById('canvas');
    apply(c);
  });
  function bind(){
    var c = document.getElementById('canvas');
    if (!c){ setTimeout(bind, 30); return; }
    apply(c);
    obs.observe(c, {attributes:true, attributeFilter:['style','width','height']});
    window.addEventListener('resize', function(){ apply(c); });
    window.addEventListener('orientationchange', function(){
      setTimeout(function(){ apply(c); }, 100);
    });
  }
  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', bind);
  else bind();
})();

// Native Web Audio via OscillatorNode. Replaces pygame.mixer, which is
// unreliable in pygbag/Pyodide (pygbag issue #19 / discussion #88).
// Oscillators are the simplest, most reliable Web Audio primitive; they
// cannot produce silent output due to sample-format or sample-rate issues.
// Python calls window.skyPlay(name, volume) via the Pyodide `js` module.
(function(){
  var ctx = null;
  var ready = false;

  // Each sound is a list of (durS, f0, f1, shape, vol) segments.
  // attack_s/release_s are fixed per segment (10ms/60ms) to keep defs terse.
  var S = {
    flap:        [[0.07,  260,  520, 'square',   0.40]],
    coin:        [[0.10,  880, 1320, 'sine',     0.50]],
    coin_combo:  [[0.13, 1175, 1760, 'sine',     0.55]],
    coin_triple: [[0.05,  880,  880, 'sine',     0.45],
                  [0.06, 1175, 1175, 'sine',     0.50],
                  [0.08, 1568, 1568, 'sine',     0.55]],
    mushroom:    [[0.08,  523,  523, 'triangle', 0.50],
                  [0.08,  659,  659, 'triangle', 0.50],
                  [0.14,  784,  988, 'triangle', 0.60]],
    magnet:      [[0.10,  220,  660, 'triangle', 0.50],
                  [0.12,  660,  990, 'sine',     0.52]],
    slowmo:      [[0.10,  880,  660, 'triangle', 0.48],
                  [0.10,  660,  440, 'triangle', 0.50],
                  [0.18,  440,  220, 'sine',     0.55]],
    thunder:     [[0.20,   80,   60, 'triangle', 0.48],
                  [0.20,   60,   50, 'triangle', 0.45],
                  [0.40,   50,   40, 'sine',     0.42]],
    death:       [[0.32,  330,   90, 'square',   0.55]],
    gameover:    [[0.12,  523,  523, 'triangle', 0.45],
                  [0.12,  440,  440, 'triangle', 0.45],
                  [0.14,  349,  349, 'triangle', 0.48],
                  [0.18,  262,  262, 'triangle', 0.52]]
  };

  // Play a short beep inline — proves Web Audio works end-to-end.
  // Called once on the first user gesture.
  function beep() {
    if (!ctx) return;
    try {
      var osc = ctx.createOscillator();
      var g = ctx.createGain();
      osc.type = 'sine';
      osc.frequency.value = 660;
      var t = ctx.currentTime;
      g.gain.setValueAtTime(0.0001, t);
      g.gain.exponentialRampToValueAtTime(0.3, t + 0.01);
      g.gain.exponentialRampToValueAtTime(0.0001, t + 0.15);
      osc.connect(g); g.connect(ctx.destination);
      osc.start(t); osc.stop(t + 0.16);
      console.log('[skyAudio] beep test scheduled at', t.toFixed(3));
    } catch(e) { console.warn('[skyAudio] beep failed:', e); }
  }

  function ensureCtx() {
    if (ctx) return ctx;
    try {
      var AC = window.AudioContext || window.webkitAudioContext;
      if (!AC) { console.warn('[skyAudio] no AudioContext support'); return null; }
      ctx = new AC();  // intentionally no sampleRate hint — let browser pick
      console.log('[skyAudio] AudioContext created, state=', ctx.state,
                  'sampleRate=', ctx.sampleRate);
      return ctx;
    } catch(e) { console.warn('[skyAudio] ctx create failed:', e); return null; }
  }

  function unlock() {
    var c = ensureCtx();
    if (!c) return;
    if (c.state !== 'running') {
      c.resume().then(function(){
        console.log('[skyAudio] ctx resumed → state=', c.state);
        if (!ready) { ready = true; beep(); }
      }, function(err){
        console.warn('[skyAudio] resume rejected:', err);
      });
    } else if (!ready) {
      ready = true;
      beep();
    }
  }
  ['click','touchstart','touchend','pointerdown','keydown'].forEach(function(t){
    document.addEventListener(t, unlock, {capture:true, passive:true});
  });

  // Schedule one segment: oscillator + per-segment envelope.
  function playSegment(tStart, durS, f0, f1, shape, segVol, masterVol) {
    var osc = ctx.createOscillator();
    osc.type = shape === 'triangle' ? 'triangle'
             : shape === 'square'   ? 'square'
             : 'sine';
    osc.frequency.setValueAtTime(f0, tStart);
    if (f0 !== f1) osc.frequency.linearRampToValueAtTime(f1, tStart + durS);

    var g = ctx.createGain();
    var peak = Math.max(0.0001, segVol * masterVol);
    var atk = 0.005, rel = Math.min(0.06, durS * 0.4);
    g.gain.setValueAtTime(0.0001, tStart);
    g.gain.exponentialRampToValueAtTime(peak, tStart + atk);
    g.gain.setValueAtTime(peak, tStart + durS - rel);
    g.gain.exponentialRampToValueAtTime(0.0001, tStart + durS);

    osc.connect(g); g.connect(ctx.destination);
    osc.start(tStart);
    osc.stop(tStart + durS + 0.02);
  }

  // Global entry point called from Python (audio.py).
  window.skyPlay = function(name, volume) {
    if (!ctx) { console.warn('[skyAudio] skyPlay(', name, ') before ctx'); return; }
    if (ctx.state !== 'running') {
      console.warn('[skyAudio] skyPlay(', name, ') ctx state=', ctx.state);
      // best-effort: try to resume even without a gesture
      ctx.resume();
      return;
    }
    var segs = S[name];
    if (!segs) { console.warn('[skyAudio] unknown sound:', name); return; }
    var v = typeof volume === 'number' ? volume : 1.0;
    var t = ctx.currentTime + 0.005;  // tiny lookahead to avoid glitches
    for (var i = 0; i < segs.length; i++) {
      var s = segs[i];
      playSegment(t, s[0], s[1], s[2], s[3], s[4], v);
      t += s[0];
    }
  };
  console.log('[skyAudio] skyPlay installed; sounds:', Object.keys(S).join(','));

  // ── Background music ──────────────────────────────────────────────────────
  // Instant-Crush-inspired loop, synthesised offline once (fast in JS via
  // OfflineAudioContext), then looped via AudioBufferSourceNode.
  var _musicBuffer = null;
  var _musicSource = null;
  var _musicGain = null;
  var _musicRequested = false;
  var _musicRendering = false;

  // Warm lo-fi / ambient progression — jazz extended chords (7ths / 9ths).
  // Cmaj7 → Am9 → Fmaj7 → G7sus4. Progression cycles 4× across the
  // 16-bar loop so the 4 evolving sections each get a full chord cycle.
  var _BPM = 78, _BAR = 60.0 / _BPM * 4, _BEAT = 60.0 / _BPM;
  var _CHORDS = [
    [60, [0, 4, 7, 11]],       // Cmaj7
    [57, [0, 3, 7, 10, 14]],   // Am9
    [53, [0, 4, 7, 11]],       // Fmaj7
    [55, [0, 5, 7, 10]]        // G7sus4
  ];
  var _BARS_TOTAL = 16;
  var _BARS_PER_SECTION = 4;
  // Per-section layer enablement: [sub, pad, arp, kick, lead]
  var _SECTIONS = [
    [true, true, false, false, false],  // A: pad + sub only
    [true, true, true,  false, false],  // B: + arp
    [true, true, true,  true,  true ],  // C: full
    [true, true, true,  false, false]   // D: breath
  ];
  // 8-note arp pattern per section (index into chord offsets).
  var _ARP_PATTERNS = [
    [0,1,2,3,2,1,0,1],   // asc-desc
    [0,2,1,3,2,0,3,1],   // zig-zag
    [0,2,3,2,1,3,2,0],   // syncopated
    [0,2,1,3,0,2,1,3]    // stepwise
  ];
  var _LEAD_DEGS = [0, 7, 11, 14, 7, 11, 0, 7];

  function _midiHz(m) { return 440.0 * Math.pow(2, (m - 69) / 12.0); }

  function _schedulePadVoice(octx, tStart, dur, freq, detuneCents, vol) {
    var o = octx.createOscillator();
    o.type = 'triangle';
    o.frequency.value = freq;
    o.detune.value = detuneCents;
    var g = octx.createGain();
    g.gain.setValueAtTime(0.0001, tStart);
    g.gain.exponentialRampToValueAtTime(vol, tStart + 0.12);
    g.gain.setValueAtTime(vol, tStart + dur - 0.18);
    g.gain.exponentialRampToValueAtTime(0.0001, tStart + dur);
    o.connect(g); g.connect(octx.destination);
    o.start(tStart); o.stop(tStart + dur + 0.02);
  }
  function _scheduleBassNote(octx, tStart, dur, freq, vol) {
    var o = octx.createOscillator(); o.type = 'square'; o.frequency.value = freq;
    var g = octx.createGain();
    g.gain.setValueAtTime(0.0001, tStart);
    g.gain.exponentialRampToValueAtTime(vol, tStart + 0.005);
    g.gain.setValueAtTime(vol, tStart + dur - 0.04);
    g.gain.exponentialRampToValueAtTime(0.0001, tStart + dur);
    o.connect(g); g.connect(octx.destination);
    o.start(tStart); o.stop(tStart + dur + 0.02);
  }
  function _scheduleLeadNote(octx, tStart, dur, freq, detune, vol) {
    var o = octx.createOscillator(); o.type = 'sine';
    o.frequency.value = freq; o.detune.value = detune;
    var g = octx.createGain();
    g.gain.setValueAtTime(0.0001, tStart);
    g.gain.exponentialRampToValueAtTime(vol, tStart + 0.008);
    g.gain.exponentialRampToValueAtTime(0.0001, tStart + dur);
    o.connect(g); g.connect(octx.destination);
    o.start(tStart); o.stop(tStart + dur + 0.02);
  }
  function _scheduleKick(octx, tStart, vol) {
    var o = octx.createOscillator(); o.type = 'sine';
    o.frequency.setValueAtTime(60, tStart);
    o.frequency.exponentialRampToValueAtTime(40, tStart + 0.09);
    var g = octx.createGain();
    g.gain.setValueAtTime(vol, tStart);
    g.gain.exponentialRampToValueAtTime(0.0001, tStart + 0.09);
    o.connect(g); g.connect(octx.destination);
    o.start(tStart); o.stop(tStart + 0.1);
  }

  function _scheduleSubBass(octx, tStart, dur, freq, vol) {
    var o = octx.createOscillator(); o.type = 'sine'; o.frequency.value = freq;
    var g = octx.createGain();
    g.gain.setValueAtTime(0.0001, tStart);
    g.gain.exponentialRampToValueAtTime(vol, tStart + 0.35);
    g.gain.setValueAtTime(vol, tStart + dur - 0.35);
    g.gain.exponentialRampToValueAtTime(0.0001, tStart + dur);
    o.connect(g); g.connect(octx.destination);
    o.start(tStart); o.stop(tStart + dur + 0.02);
  }
  function _scheduleArpNote(octx, tStart, dur, freq, vol) {
    var o = octx.createOscillator(); o.type = 'sine'; o.frequency.value = freq;
    var g = octx.createGain();
    g.gain.setValueAtTime(0.0001, tStart);
    g.gain.exponentialRampToValueAtTime(vol, tStart + 0.008);
    g.gain.exponentialRampToValueAtTime(0.0001, tStart + dur);
    o.connect(g); g.connect(octx.destination);
    o.start(tStart); o.stop(tStart + dur + 0.02);
  }

  function _renderMusicBuffer() {
    if (!ctx) return Promise.reject('no ctx');
    var totalSec = _BARS_TOTAL * _BAR;
    var sr = ctx.sampleRate;
    var octx = new (window.OfflineAudioContext || window.webkitOfflineAudioContext)(
      1, Math.ceil(totalSec * sr), sr);
    for (var bar = 0; bar < _BARS_TOTAL; bar++) {
      var sec = _SECTIONS[Math.floor(bar / _BARS_PER_SECTION) % _SECTIONS.length];
      var chord = _CHORDS[bar % _CHORDS.length];
      var root = chord[0], offs = chord[1];
      var barStart = bar * _BAR;
      // Sub-bass
      if (sec[0]) {
        _scheduleSubBass(octx, barStart, _BAR * 0.95, _midiHz(root - 12), 0.18);
      }
      // Pad — full extended chord × 2 detuned triangles
      if (sec[1]) {
        for (var ti = 0; ti < offs.length; ti++) {
          var f = _midiHz(root + offs[ti]);
          // Slow-swell pad: longer attack/release envelope.
          var ostart = barStart, odur = _BAR * 0.98;
          for (var dd = 0; dd < 2; dd++) {
            var det = dd === 0 ? -5 : +5;
            var o = octx.createOscillator(); o.type = 'triangle';
            o.frequency.value = f; o.detune.value = det;
            var g = octx.createGain();
            g.gain.setValueAtTime(0.0001, ostart);
            g.gain.exponentialRampToValueAtTime(0.045, ostart + 0.45);
            g.gain.setValueAtTime(0.045, ostart + odur - 0.55);
            g.gain.exponentialRampToValueAtTime(0.0001, ostart + odur);
            o.connect(g); g.connect(octx.destination);
            o.start(ostart); o.stop(ostart + odur + 0.02);
          }
        }
      }
      // Arpeggio
      if (sec[2]) {
        var pat = _ARP_PATTERNS[Math.floor(bar / _BARS_PER_SECTION) % _ARP_PATTERNS.length];
        var noteDur = _BEAT * 0.45;
        for (var i = 0; i < 8; i++) {
          var idx = pat[i] % offs.length;
          var note = root + offs[idx] + 12;
          var t = barStart + i * (_BEAT / 2);
          _scheduleArpNote(octx, t, noteDur, _midiHz(note), 0.07);
        }
      }
      // Soft kick on beats 1 & 3
      if (sec[3]) {
        _scheduleKick(octx, barStart + 0 * _BEAT, 0.45);
        _scheduleKick(octx, barStart + 2 * _BEAT, 0.45);
      }
      // Lead
      if (sec[4]) {
        var base = (bar % 4) * 2;
        for (var li = 0; li < 2; li++) {
          var deg = _LEAD_DEGS[(base + li) % _LEAD_DEGS.length];
          var tl = barStart + li * (_BAR / 2);
          _scheduleLeadNote(octx, tl, _BAR * 0.48, _midiHz(root + deg + 12), -4, 0.085);
          _scheduleLeadNote(octx, tl, _BAR * 0.48, _midiHz(root + deg + 12), +4, 0.085);
        }
      }
    }
    return octx.startRendering();
  }

  function _actuallyStartMusic(vol) {
    if (!ctx || !_musicBuffer) return;
    try { if (_musicSource) _musicSource.stop(); } catch (e) {}
    _musicSource = ctx.createBufferSource();
    _musicSource.buffer = _musicBuffer;
    _musicSource.loop = true;
    _musicGain = ctx.createGain();
    _musicGain.gain.value = typeof vol === 'number' ? vol : 0.22;
    _musicSource.connect(_musicGain); _musicGain.connect(ctx.destination);
    _musicSource.start(ctx.currentTime + 0.05);
    console.log('[skyAudio] music started, buffer=', _musicBuffer.duration.toFixed(1), 's');
  }

  window.skyMusicStart = function(volume) {
    _musicRequested = true;
    var c = ensureCtx(); if (!c) return;
    if (c.state !== 'running') { c.resume(); }
    if (_musicBuffer) { _actuallyStartMusic(volume); return; }
    if (_musicRendering) return;
    _musicRendering = true;
    _renderMusicBuffer().then(function(buf) {
      _musicBuffer = buf; _musicRendering = false;
      if (_musicRequested) _actuallyStartMusic(volume);
    }, function(err) {
      console.warn('[skyAudio] music render failed:', err);
      _musicRendering = false;
    });
  };
  window.skyMusicPause = function() {
    if (ctx && ctx.state === 'running') { ctx.suspend(); }
  };
  window.skyMusicResume = function() {
    if (ctx && ctx.state === 'suspended') { ctx.resume(); }
  };
  window.skyMusicStop = function(fadeoutMs) {
    _musicRequested = false;
    if (!_musicSource || !_musicGain) return;
    var src = _musicSource, g = _musicGain;
    _musicSource = null; _musicGain = null;
    var fade = (typeof fadeoutMs === 'number' ? fadeoutMs : 800) / 1000;
    try {
      var t = ctx.currentTime;
      g.gain.setValueAtTime(g.gain.value, t);
      g.gain.exponentialRampToValueAtTime(0.0001, t + fade);
      src.stop(t + fade + 0.05);
    } catch (e) { try { src.stop(); } catch (e2) {} }
  };
  console.log('[skyAudio] skyMusic* installed');
})();
</script>
