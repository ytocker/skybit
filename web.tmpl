// Force canvas CSS dimensions with inline !important. MutationObserver
// re-applies on every mutation (beats emscripten Browser.updateCanvasDimensions
// inline !important — verified behavior per emscripten issue #6353).
(function(){
  'use strict';
  function apply(c){
    if (!c) return;
    var vw = window.innerWidth, vh = window.innerHeight;
    if (c.style.width === vw + 'px' && c.style.height === vh + 'px') return;
    c.style.setProperty('position',        'fixed',     'important');
    c.style.setProperty('left',            '0',         'important');
    c.style.setProperty('top',             '0',         'important');
    c.style.setProperty('right',           'auto',      'important');
    c.style.setProperty('bottom',          'auto',      'important');
    c.style.setProperty('width',           vw + 'px',   'important');
    c.style.setProperty('height',          vh + 'px',   'important');
    c.style.setProperty('margin',          '0',         'important');
    c.style.setProperty('transform',       'none',      'important');
    c.style.setProperty('image-rendering', 'pixelated', 'important');
    c.style.setProperty('z-index',         '1',         'important');
    c.style.setProperty('display',         'block',     'important');
  }
  var obs = new MutationObserver(function(){
    var c = document.getElementById('canvas');
    apply(c);
  });
  function bind(){
    var c = document.getElementById('canvas');
    if (!c){ setTimeout(bind, 30); return; }
    apply(c);
    obs.observe(c, {attributes:true, attributeFilter:['style','width','height']});
    window.addEventListener('resize', function(){ apply(c); });
    window.addEventListener('orientationchange', function(){
      setTimeout(function(){ apply(c); }, 100);
    });
  }
  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', bind);
  else bind();
})();

// Native Web Audio via OscillatorNode. Replaces pygame.mixer, which is
// unreliable in pygbag/Pyodide (pygbag issue #19 / discussion #88).
// Oscillators are the simplest, most reliable Web Audio primitive; they
// cannot produce silent output due to sample-format or sample-rate issues.
// Python calls window.skyPlay(name, volume) via the Pyodide `js` module.
(function(){
  var ctx = null;
  var ready = false;

  // Each sound is a list of (durS, f0, f1, shape, vol) segments.
  // attack_s/release_s are fixed per segment (10ms/60ms) to keep defs terse.
  var S = {
    flap:        [[0.07,  260,  520, 'square',   0.40]],
    coin:        [[0.10,  880, 1320, 'sine',     0.50]],
    coin_combo:  [[0.13, 1175, 1760, 'sine',     0.55]],
    coin_triple: [[0.05,  880,  880, 'sine',     0.45],
                  [0.06, 1175, 1175, 'sine',     0.50],
                  [0.08, 1568, 1568, 'sine',     0.55]],
    mushroom:    [[0.08,  523,  523, 'triangle', 0.50],
                  [0.08,  659,  659, 'triangle', 0.50],
                  [0.14,  784,  988, 'triangle', 0.60]],
    magnet:      [[0.10,  220,  660, 'triangle', 0.50],
                  [0.12,  660,  990, 'sine',     0.52]],
    slowmo:      [[0.10,  880,  660, 'triangle', 0.48],
                  [0.10,  660,  440, 'triangle', 0.50],
                  [0.18,  440,  220, 'sine',     0.55]],
    thunder:     [[0.20,   80,   60, 'triangle', 0.48],
                  [0.20,   60,   50, 'triangle', 0.45],
                  [0.40,   50,   40, 'sine',     0.42]],
    death:       [[0.32,  330,   90, 'square',   0.55]],
    gameover:    [[0.12,  523,  523, 'triangle', 0.45],
                  [0.12,  440,  440, 'triangle', 0.45],
                  [0.14,  349,  349, 'triangle', 0.48],
                  [0.18,  262,  262, 'triangle', 0.52]]
  };

  // Play a short beep inline — proves Web Audio works end-to-end.
  // Called once on the first user gesture.
  function beep() {
    if (!ctx) return;
    try {
      var osc = ctx.createOscillator();
      var g = ctx.createGain();
      osc.type = 'sine';
      osc.frequency.value = 660;
      var t = ctx.currentTime;
      g.gain.setValueAtTime(0.0001, t);
      g.gain.exponentialRampToValueAtTime(0.3, t + 0.01);
      g.gain.exponentialRampToValueAtTime(0.0001, t + 0.15);
      osc.connect(g); g.connect(ctx.destination);
      osc.start(t); osc.stop(t + 0.16);
      console.log('[skyAudio] beep test scheduled at', t.toFixed(3));
    } catch(e) { console.warn('[skyAudio] beep failed:', e); }
  }

  function ensureCtx() {
    if (ctx) return ctx;
    try {
      var AC = window.AudioContext || window.webkitAudioContext;
      if (!AC) { console.warn('[skyAudio] no AudioContext support'); return null; }
      ctx = new AC();  // intentionally no sampleRate hint — let browser pick
      console.log('[skyAudio] AudioContext created, state=', ctx.state,
                  'sampleRate=', ctx.sampleRate);
      return ctx;
    } catch(e) { console.warn('[skyAudio] ctx create failed:', e); return null; }
  }

  function unlock() {
    var c = ensureCtx();
    if (!c) return;
    if (c.state !== 'running') {
      c.resume().then(function(){
        console.log('[skyAudio] ctx resumed → state=', c.state);
        if (!ready) { ready = true; beep(); }
      }, function(err){
        console.warn('[skyAudio] resume rejected:', err);
      });
    } else if (!ready) {
      ready = true;
      beep();
    }
  }
  ['click','touchstart','touchend','pointerdown','keydown'].forEach(function(t){
    document.addEventListener(t, unlock, {capture:true, passive:true});
  });

  // Schedule one segment: oscillator + per-segment envelope.
  function playSegment(tStart, durS, f0, f1, shape, segVol, masterVol) {
    var osc = ctx.createOscillator();
    osc.type = shape === 'triangle' ? 'triangle'
             : shape === 'square'   ? 'square'
             : 'sine';
    osc.frequency.setValueAtTime(f0, tStart);
    if (f0 !== f1) osc.frequency.linearRampToValueAtTime(f1, tStart + durS);

    var g = ctx.createGain();
    var peak = Math.max(0.0001, segVol * masterVol);
    var atk = 0.005, rel = Math.min(0.06, durS * 0.4);
    g.gain.setValueAtTime(0.0001, tStart);
    g.gain.exponentialRampToValueAtTime(peak, tStart + atk);
    g.gain.setValueAtTime(peak, tStart + durS - rel);
    g.gain.exponentialRampToValueAtTime(0.0001, tStart + durS);

    osc.connect(g); g.connect(ctx.destination);
    osc.start(tStart);
    osc.stop(tStart + durS + 0.02);
  }

  // Global entry point called from Python (audio.py).
  window.skyPlay = function(name, volume) {
    if (!ctx) { console.warn('[skyAudio] skyPlay(', name, ') before ctx'); return; }
    if (ctx.state !== 'running') {
      console.warn('[skyAudio] skyPlay(', name, ') ctx state=', ctx.state);
      // best-effort: try to resume even without a gesture
      ctx.resume();
      return;
    }
    var segs = S[name];
    if (!segs) { console.warn('[skyAudio] unknown sound:', name); return; }
    var v = typeof volume === 'number' ? volume : 1.0;
    var t = ctx.currentTime + 0.005;  // tiny lookahead to avoid glitches
    for (var i = 0; i < segs.length; i++) {
      var s = segs[i];
      playSegment(t, s[0], s[1], s[2], s[3], s[4], v);
      t += s[0];
    }
  };
  console.log('[skyAudio] skyPlay installed; sounds:', Object.keys(S).join(','));
})();
</script>
